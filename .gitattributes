# Automatikus sortörés normalizálása
* text=auto

# NYELVI BESOROLÁSOK
*.html         linguist-language=HTML
*.css          linguist-language=CSS
*.js           linguist-language=JavaScript
*.json         linguist-detectable=true
*.geojson      linguist-detectable=false

# Bináris fájlok
*.png          binary
*.jpg          binary
*.svg          binary

# Dokumentációs fájlok
README.md      linguist-documentation=true
.gitignore     linguist-documentation=true
.gitattributes linguist-documentation=true

# Forrásfájlok kiemelése
index.html     linguist-vendored=false
app.js         linguist-vendored=false
search.js      linguist-vendored=false
style.css      linguist-vendored=false
